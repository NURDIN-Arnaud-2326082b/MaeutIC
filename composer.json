{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.2",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/dbal": "^4.4.2",
    "doctrine/doctrine-bundle": "^2.18.2",
    "doctrine/doctrine-migrations-bundle": "^3.7.0",
    "doctrine/orm": "^3.6.2",
    "symfony/asset": "^7.4.6",
    "symfony/asset-mapper": "^7.4.6",
    "symfony/console": "^7.4.7",
    "symfony/dotenv": "^7.4.7",
    "symfony/flex": "^2.10.0",
    "symfony/form": "^7.4.7",
    "symfony/framework-bundle": "^7.4.7",
    "symfony/mailer": "^7.4.6",
    "symfony/mime": "^7.4.7",
    "symfony/runtime": "^7.4.1",
    "symfony/security-bundle": "^7.4.6",
    "symfony/stimulus-bundle": "^2.33",
    "symfony/translation": "^7.4.6",
    "symfony/twig-bundle": "^7.4.4",
    "symfony/ux-turbo": "^2.33",
    "symfony/validator": "^7.4.7",
    "symfony/yaml": "^7.4.6",
    "symfonycasts/tailwind-bundle": "^0.8.0",
    "symfonycasts/verify-email-bundle": "^1.18.0",
    "twig/extra-bundle": "^2.12|^3.24.0",
    "twig/twig": "^2.12|^3.24.0"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "bump-after-update": true,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "importmap:install": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^7.3"
    }
  },
  "require-dev": {
    "doctrine/doctrine-fixtures-bundle": "^4.3.1",
    "phpunit/phpunit": "^12.5.14",
    "symfony/maker-bundle": "^1.66",
    "symfony/stopwatch": "^7.4",
    "symfony/web-profiler-bundle": "^7.4.7"
  }
}
