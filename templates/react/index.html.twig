<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>M@ieutIC</title>
    
    {# PWA Configuration #}
    <link rel="manifest" href="{{ asset('manifest.json') }}">
    <meta name="theme-color" content="#4F46E5">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="M@ieutIC">
    <link rel="apple-touch-icon" href="{{ asset('images/icons/ios/180.png') }}">
    
    {# Development vs Production #}
    {% if app.environment == 'dev' %}
        {# Vite Dev Server #}
        <script type="module" src="http://localhost:3000/@vite/client"></script>
        <script type="module" src="http://localhost:3000/src/main.jsx"></script>
    {% else %}
        {# Production Build #}
        {% if manifest and manifest['src/main.jsx'] is defined %}
            {% if manifest['src/main.jsx']['css'] is defined %}
                <link rel="stylesheet" href="{{ asset('react/' ~ manifest['src/main.jsx']['css'][0]) }}">
            {% endif %}
            <script type="module" src="{{ asset('react/' ~ manifest['src/main.jsx']['file']) }}"></script>
        {% else %}
            {# Keep production deterministic: never fallback to local Vite dev server. #}
            <meta name="robots" content="noindex,nofollow">
        {% endif %}
    {% endif %}
</head>
<body class="min-h-screen flex flex-col">
    <div id="root"></div>
    {% if app.environment != 'dev' and (manifest is not defined or manifest is null or manifest['src/main.jsx'] is not defined) %}
        <noscript>Le build React est introuvable. Merci de contacter l'administrateur.</noscript>
    {% endif %}
</body>
</html>
